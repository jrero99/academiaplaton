// Schema Prisma — Academia Platón CRM
// Datasource MySQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  new
  contacted
  visit_scheduled
  trial_class
  converted
  lost
}

enum LeadSource {
  web
  referral
  instagram
  phone
  walk_in
  other
}

enum GuardianRelationship {
  mother
  father
  tutor
  other
}

model Lead {
  id               String     @id @default(uuid()) @db.Char(36)
  firstName        String     @db.VarChar(80)
  lastName         String     @db.VarChar(120)
  email            String?    @db.VarChar(160)
  phone            String?    @db.VarChar(20)
  source           LeadSource
  status           LeadStatus @default(new)
  notes            String?    @db.Text
  interestedCourse String?    @db.VarChar(120)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  convertedStudent Student?

  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model Student {
  id        String   @id @default(uuid()) @db.Char(36)
  firstName String   @db.VarChar(80)
  lastName  String   @db.VarChar(120)
  birthDate DateTime @db.Date
  email     String?  @db.VarChar(160)
  phone     String?  @db.VarChar(20)
  address   String?  @db.VarChar(240)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromLeadId String? @unique @db.Char(36)
  fromLead   Lead?   @relation(fields: [fromLeadId], references: [id], onDelete: SetNull)

  guardians Guardian[]

  @@index([lastName, firstName])
}

model Guardian {
  id           String               @id @default(uuid()) @db.Char(36)
  firstName    String               @db.VarChar(80)
  lastName     String               @db.VarChar(120)
  relationship GuardianRelationship
  phone        String               @db.VarChar(20)
  email        String?              @db.VarChar(160)

  studentId String  @db.Char(36)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}
