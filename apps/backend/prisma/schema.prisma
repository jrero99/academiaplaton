// Schema Prisma — Plató SaaS (multi-tenant).
// Cada Organization es un tenant. Toda entidad de dominio lleva organizationId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums — módulo attendance
// ─────────────────────────────────────────────────────────────────────────────

enum AttendanceStatus {
  present
  absent
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums — módulo scheduling (tipo de clase y estado de sesión)
// ─────────────────────────────────────────────────────────────────────────────

enum ClassType {
  PARTICULAR
  SEMIPARTICULAR
  GRUPAL
}

enum SessionStatus {
  scheduled
  completed
  cancelled
}

enum UserRole {
  admin
  center_manager
  teacher
}

model Organization {
  id   String @id @default(uuid()) @db.Char(36)
  slug String @unique @db.VarChar(80)
  name String @db.VarChar(160)

  // Branding (white-label)
  logoUrl       String? @db.VarChar(500)
  primaryColor  String? @db.Char(7) // hex #RRGGBB
  accentColor   String? @db.Char(7)

  // Módulos habilitados (CSV simple en MySQL: "crm,billing,scheduling,communications").
  // Con MySQL no hay arrays nativos, usamos String. Validación con Zod en el backend.
  enabledModules String @default("crm") @db.VarChar(255)

  // Integraciones (cifrado en backend antes de guardar)
  n8nWebhookUrl       String? @db.VarChar(500)
  whatsappPhoneNumberId String? @db.VarChar(80)
  whatsappAccessToken   String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships  UserOrganization[]
  leads        Lead[]
  students     Student[]
  teachers     Teacher[]
  centers      Center[]
  groups       Group[]
  sessions     Session[]
  sepaMandates SepaMandate[]
  invoices     Invoice[]
  attendances  Attendance[]
  teacherRates TeacherRate[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Centros (sedes) — sub-entidad dentro de Organization
// ─────────────────────────────────────────────────────────────────────────────

model Center {
  id             String  @id @default(uuid()) @db.Char(36)
  organizationId String  @db.Char(36)
  slug           String  @db.VarChar(80)
  name           String  @db.VarChar(160)
  address        String? @db.VarChar(240)
  phone          String? @db.VarChar(20)
  email          String? @db.VarChar(160)
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  students     Student[]
  teachers     Teacher[]
  groups       Group[]
  sessions     Session[]

  @@unique([organizationId, slug])
  @@index([organizationId, active])
}

model User {
  id           String   @id @default(uuid()) @db.Char(36)
  email        String   @unique @db.VarChar(160)
  passwordHash String   @db.VarChar(255)
  firstName    String   @db.VarChar(80)
  lastName     String   @db.VarChar(120)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships         UserOrganization[]
  attendancesMarked   Attendance[]
}

model UserOrganization {
  id             String  @id @default(uuid()) @db.Char(36)
  userId         String  @db.Char(36)
  organizationId String  @db.Char(36)

  // Roles en CSV ("admin,teacher"). Sin arrays nativos en MySQL; mismo patrón
  // que Organization.enabledModules. El repo parsea con parseRoles() / serializeRoles().
  // Al menos un rol requerido — validado en Zod (shared/users.ts).
  roles          String  @default("admin") @db.VarChar(255)

  // Vínculo opcional a Teacher: permite que un admin/center_manager que también
  // imparte clases comparta el mismo registro Teacher en grupos/sesiones.
  // Constraint de misma org se valida en service, no en FK compuesta (Prisma no lo soporta).
  teacherId      String? @db.Char(36)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher      Teacher?     @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([organizationId, teacherId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CRM — Leads y Students
// ─────────────────────────────────────────────────────────────────────────────

enum LeadStatus {
  new
  contacted
  visit_scheduled
  trial_class
  converted
  lost
}

enum LeadSource {
  web
  referral
  instagram
  phone
  walk_in
  other
}

enum GuardianRelationship {
  mother
  father
  tutor
  other
}

// ─────────────────────────────────────────────────────────────────────────────
// Fiscalidad y pagos
// ─────────────────────────────────────────────────────────────────────────────

enum PaymentMethod {
  cash
  sepa
  bank_transfer
  other
}

enum SepaMandateType {
  core  // Adeudo SEPA básico (consumidores)
  b2b   // Adeudo SEPA B2B (entre empresas)
}

enum SepaDebitType {
  recurrent  // RCUR — adeudos periódicos
  one_off    // OOFF — un único cobro
}

enum SepaMandateStatus {
  active
  paused
  revoked
}

enum InvoiceStatus {
  pending    // creada, aún sin enviar cobro
  sent       // cobro enviado al pagador
  paid       // cobrada
  overdue    // vencida sin cobrar
  cancelled  // anulada
}

model Lead {
  id               String     @id @default(uuid()) @db.Char(36)
  organizationId   String     @db.Char(36)
  firstName        String     @db.VarChar(80)
  lastName         String     @db.VarChar(120)
  email            String?    @db.VarChar(160)
  phone            String?    @db.VarChar(20)
  source           LeadSource
  status           LeadStatus @default(new)
  notes            String?    @db.Text
  interestedCourse String?    @db.VarChar(120)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  convertedStudent Student?

  @@index([organizationId, status])
  @@index([organizationId, source])
  @@index([organizationId, createdAt])
}

model Student {
  id             String   @id @default(uuid()) @db.Char(36)
  organizationId String   @db.Char(36)
  centerId       String   @db.Char(36)
  firstName      String   @db.VarChar(80)
  lastName       String   @db.VarChar(120)
  birthDate      DateTime @db.Date
  email          String?  @db.VarChar(160)
  phone          String?  @db.VarChar(20)
  address        String?  @db.VarChar(240)
  notes          String?  @db.Text

  // Cuota mensual (€). Base para generar recibos del módulo billing.
  monthlyFee     Decimal? @db.Decimal(8, 2)

  // Fiscalidad / facturación: datos para emitir factura.
  // Pueden estar vacíos si el alumno no requiere factura nominal.
  taxId          String? @db.VarChar(20)  // NIF/DNI del alumno (si aplica)
  billingName    String? @db.VarChar(160) // Razón social / nombre en la factura
  billingTaxId   String? @db.VarChar(20)  // NIF del facturado (alumno o responsable)
  billingAddress String? @db.VarChar(240)
  billingEmail   String? @db.VarChar(160)

  // Método de pago habitual del alumno
  paymentMethod PaymentMethod @default(cash)

  // Mandato SEPA asociado (solo si paymentMethod = sepa).
  // Varios alumnos (hermanos) pueden compartir el mismo mandato → N:1.
  sepaMandateId String?      @db.Char(36)
  sepaMandate   SepaMandate? @relation(fields: [sepaMandateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromLeadId String? @unique @db.Char(36)
  fromLead   Lead?   @relation(fields: [fromLeadId], references: [id], onDelete: SetNull)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  center       Center         @relation(fields: [centerId], references: [id], onDelete: Restrict)
  guardians    Guardian[]
  groups       GroupStudent[]
  invoices     Invoice[]
  attendances  Attendance[]

  @@index([organizationId, centerId])
  @@index([organizationId, lastName, firstName])
  @@index([organizationId, sepaMandateId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Mandato SEPA — autorización de cobro por adeudo directo.
// Los datos del titular se almacenan planos (NO relación a Guardian/Student)
// porque (a) el titular puede no estar en BD (familiar externo) y (b) el
// mandato debe ser inmutable una vez firmado aunque cambien datos del Guardian.
// TODO seguridad: cifrar `iban` antes de producción (LOPD §5 CLAUDE.md).
// ─────────────────────────────────────────────────────────────────────────────

model SepaMandate {
  id             String @id @default(uuid()) @db.Char(36)
  organizationId String @db.Char(36)

  // Referencia única del mandato (la usa el banco para identificarlo)
  reference String @db.VarChar(35) // SEPA permite hasta 35 chars

  // Datos del titular de la cuenta (snapshot en el momento de firma)
  holderName    String  @db.VarChar(160)
  holderTaxId   String  @db.VarChar(20)
  holderAddress String? @db.VarChar(240)
  holderEmail   String? @db.VarChar(160)
  holderPhone   String? @db.VarChar(20)

  // Datos bancarios
  iban String @db.VarChar(34)   // IBAN sin espacios; TODO cifrar en prod
  bic  String? @db.VarChar(11)  // opcional en SEPA zona euro

  // Configuración del mandato
  mandateType SepaMandateType   @default(core)
  debitType   SepaDebitType     @default(recurrent)
  status      SepaMandateStatus @default(active)

  signedAt   DateTime  @db.Date
  revokedAt  DateTime?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  students     Student[]

  @@unique([organizationId, reference])
  @@index([organizationId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Billing — Recibos/facturas mensuales por alumno.
// Cada recibo es atómico (1 alumno, 1 periodo). `issuedAt` queda null hasta que
// se envía el cobro al pagador (paso visible al usuario en la UI).
// `number` único por organización para evitar colisiones de numeración.
// ─────────────────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid()) @db.Char(36)
  organizationId String        @db.Char(36)
  studentId      String        @db.Char(36)

  number      String        @db.VarChar(40)
  concept     String        @db.VarChar(160)
  amount      Decimal       @db.Decimal(10, 2)
  periodMonth Int           @db.UnsignedTinyInt  // 1..12
  periodYear  Int           @db.UnsignedSmallInt // 2020..2100
  dueDate     DateTime      @db.Date
  issuedAt    DateTime?     // fecha en que se envió el cobro (null si pendiente)
  status      InvoiceStatus @default(pending)
  notes       String?       @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([organizationId, number])
  @@unique([studentId, periodYear, periodMonth])
  @@index([organizationId, status])
  @@index([organizationId, periodYear, periodMonth])
  @@index([organizationId, dueDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// Profesores — entidad de RRHH dentro de un Center
// (sin vínculo a User por ahora; se añadirá cuando se cierre el módulo auth)
// ─────────────────────────────────────────────────────────────────────────────

model Teacher {
  id             String  @id @default(uuid()) @db.Char(36)
  organizationId String  @db.Char(36)
  centerId       String  @db.Char(36)
  firstName      String  @db.VarChar(80)
  lastName       String  @db.VarChar(120)
  email          String  @db.VarChar(160)
  phone          String? @db.VarChar(20)
  // Color asignado al profesor en el calendario. Valores válidos en
  // TEACHER_COLOR_IDS (packages/shared). Único por centerId — la validación
  // se hace en el servicio porque MySQL no permite unique con NULLs en algunos
  // motores, y queremos permitir múltiples profesores sin color asignado.
  color          String? @db.VarChar(16)
  active         Boolean @default(true)
  notes          String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  center       Center            @relation(fields: [centerId], references: [id], onDelete: Restrict)
  groups       Group[]
  sessions     Session[]
  memberships  UserOrganization[]

  @@unique([organizationId, email])
  // Unicidad de color por centro. MySQL trata cada NULL como distinto, así que
  // múltiples profesores sin color asignado no colisionan; sí lo hacen dos con
  // el mismo color en el mismo center.
  @@unique([centerId, color])
  @@index([organizationId, centerId])
  @@index([organizationId, lastName, firstName])
}

model Guardian {
  id           String               @id @default(uuid()) @db.Char(36)
  firstName    String               @db.VarChar(80)
  lastName     String               @db.VarChar(120)
  relationship GuardianRelationship
  phone        String               @db.VarChar(20)
  email        String?              @db.VarChar(160)

  studentId String  @db.Char(36)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Scheduling — Grupos (MVP)
// Un Group tiene un profesor titular único (teacherId). Las sustituciones
// puntuales se modelarán en Fase 2 vía Session.teacherId (no en este modelo).
// Relación N:N con Student a través de GroupStudent.
// ─────────────────────────────────────────────────────────────────────────────

model Group {
  id               String    @id @default(uuid()) @db.Char(36)
  organizationId   String    @db.Char(36)
  centerId         String    @db.Char(36)
  teacherId        String    @db.Char(36)
  name             String    @db.VarChar(120)
  subject          String?   @db.VarChar(120)
  description      String?   @db.VarChar(240)
  active           Boolean   @default(true)
  notes            String?   @db.Text
  classType        ClassType
  capacityOverride Int?      @db.UnsignedTinyInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  center       Center         @relation(fields: [centerId], references: [id], onDelete: Restrict)
  teacher      Teacher        @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  students     GroupStudent[]
  sessions     Session[]

  @@unique([organizationId, centerId, name])
  @@index([organizationId, centerId])
  @@index([organizationId, teacherId])
  @@index([organizationId, active])
  @@index([organizationId, classType])
}

model GroupStudent {
  id        String   @id @default(uuid()) @db.Char(36)
  groupId   String   @db.Char(36)
  studentId String   @db.Char(36)
  createdAt DateTime @default(now())

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@index([studentId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Session — sesión de clase concreta de un Group en una fecha + franja horaria
// El admin coloca grupos en el calendario semanal por centro de forma manual.
// teacherId se denormaliza desde Group al crear (default), pero puede
// sobrescribirse para soportar sustituciones puntuales.
// Tiempos como strings "HH:mm" para evitar problemas de zona horaria.
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id                String        @id @default(uuid()) @db.Char(36)
  organizationId    String        @db.Char(36)
  centerId          String        @db.Char(36)
  groupId           String        @db.Char(36)
  teacherId         String        @db.Char(36)
  date              DateTime      @db.Date
  startTime         String        @db.VarChar(5)
  endTime           String        @db.VarChar(5)
  notes             String?       @db.Text
  classTypeSnapshot ClassType
  rateSnapshot      Decimal       @db.Decimal(8, 4)
  durationMinutes   Int           @db.UnsignedSmallInt
  status            SessionStatus @default(scheduled)
  cancelledAt       DateTime?
  cancelledReason   String?       @db.VarChar(240)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  center       Center       @relation(fields: [centerId], references: [id], onDelete: Restrict)
  group        Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teacher      Teacher      @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  attendances  Attendance[]

  @@index([organizationId, centerId, date])
  @@index([organizationId, teacherId, date])
  @@index([organizationId, groupId, date])
  @@index([organizationId, teacherId, status])
  @@index([organizationId, date, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// TeacherRate — tarifa por hora según tipo de clase, con histórico por fecha.
// El lookup de tarifa vigente en la fecha de una sesión se hace con:
//   validFrom <= sessionDate ORDER BY validFrom DESC LIMIT 1
// Si no hay tarifa configurada para ese classType, el service rechaza con 400.
// ─────────────────────────────────────────────────────────────────────────────

model TeacherRate {
  id             String    @id @default(uuid()) @db.Char(36)
  organizationId String    @db.Char(36)
  classType      ClassType
  ratePerHour    Decimal   @db.Decimal(8, 4)
  validFrom      DateTime  @db.Date
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, classType, validFrom])
  @@index([organizationId, classType, validFrom])
}

// ─────────────────────────────────────────────────────────────────────────────
// Attendance — registro de asistencia por (sesión, alumno)
// La primera vez que se guarda la asistencia de una sesión se materializan
// los registros de todos los alumnos del grupo en ese momento (snapshot).
// Los alumnos inscritos DESPUÉS de la sesión no aparecen retroactivamente.
// ─────────────────────────────────────────────────────────────────────────────

model Attendance {
  id             String           @id @default(uuid()) @db.Char(36)
  organizationId String           @db.Char(36)
  sessionId      String           @db.Char(36)
  studentId      String           @db.Char(36)

  status         AttendanceStatus @default(present)
  justified      Boolean          @default(false)
  // Solo significativo cuando status = absent y justified = true.
  // Texto libre opcional; máx. 500 chars.
  justification  String?          @db.VarChar(500)

  markedAt       DateTime         @default(now())
  // Quién marcó la asistencia. Nulo hasta que exista módulo auth real.
  markedByUserId String?          @db.Char(36)

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session        Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // FK opcional a User (quién marcó). SetNull si el usuario es borrado.
  markedBy       User?            @relation(fields: [markedByUserId], references: [id], onDelete: SetNull)

  // Una sola marca por (sesión, alumno)
  @@unique([sessionId, studentId])
  @@index([organizationId, sessionId])
  @@index([organizationId, studentId])
}
